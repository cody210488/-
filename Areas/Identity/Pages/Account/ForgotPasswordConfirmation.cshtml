@page
@model ForgotPasswordConfirmation

@{
    ViewData["Title"] = "信件已寄出";
}

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="content-card text-center">

            <h2 class="fw-bold mb-3 text-primary">重設密碼信已寄出</h2>

            <p class="text-muted mb-4">
                請至你的 Email 信箱查看重設密碼的連結，並依照指示完成操作。
            </p>

            <a asp-page="./Login" class="btn btn-primary w-100">
                返回登入
            </a>

        </div>

    </div>
</div>