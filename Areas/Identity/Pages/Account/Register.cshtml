@page
@model RegisterModel

@{
    ViewData["Title"] = "註冊";
}

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="content-card">

            <h2 class="text-center mb-4 fw-bold">建立帳號</h2>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">電子信箱</label>
                    <input asp-for="Input.Email" class="form-control" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">密碼</label>
                    <input asp-for="Input.Password"
                           type="password"
                           class="form-control"
                           pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z0-9]).{6,100}$"
                           title="密碼需至少 6 個字元，並包含大寫英文、小寫英文、數字與特殊符號" />

                    <div class="form-text">
                        密碼需至少 6 個字元，並包含大寫英文、小寫英文、數字與特殊符號。
                    </div>

                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label">確認密碼</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-warning w-100">註冊</button>

                <div class="text-center mt-3">
                    <a asp-page="./Login">已經有帳號？登入</a>
                </div>
            </form>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}