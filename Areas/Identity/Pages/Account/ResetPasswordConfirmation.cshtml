@page
@model ResetPasswordConfirmationModel

@{
    ViewData["Title"] = "密碼重設成功";
}

<div class="row justify-content-center">
    <div class="col-md-5">

        <div class="content-card text-center">

            <h2 class="fw-bold mb-3 text-success">密碼已成功重設</h2>

            <p class="text-muted mb-4">
                你的密碼已更新完成，請重新登入。
            </p>

            <a asp-page="./Login" class="btn btn-primary w-100">
                前往登入
            </a>

        </div>

    </div>
</div>