@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "重設密碼";
}

<h1 class="page-title text-center">重設密碼</h1>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="content-card">
            <p class="text-muted text-center mb-4">請輸入帳號 Email 與新密碼</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <input asp-for="Input.Code" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email"
                           class="form-control"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">新密碼</label>
                    <input asp-for="Input.Password"
                           class="form-control"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="請輸入新密碼" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label">確認新密碼</label>
                    <input asp-for="Input.ConfirmPassword"
                           class="form-control"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="請再次輸入新密碼" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">重設密碼</button>

                <div class="text-center mt-3">
                    <a asp-page="./Login">返回登入</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}