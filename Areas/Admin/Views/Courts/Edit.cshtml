@model 打球啊.Models.Court
@{
    ViewData["Title"] = "編輯球場";
}

<h1>編輯球場</h1>

<form asp-area="Admin" asp-controller="Courts" asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">球場名稱</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="City" class="form-label">城市</label>
        <select asp-for="City" id="citySelect" class="form-select">
            <option value="">請選擇城市</option>
        </select>
        <span asp-validation-for="City" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="District" class="form-label">地區</label>
        <select asp-for="District" id="districtSelect" class="form-select">
            <option value="">請選擇地區</option>
        </select>
        <span asp-validation-for="District" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">地址</label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CourtType" class="form-label">球場類型</label>
        <input asp-for="CourtType" class="form-control" />
        <span asp-validation-for="CourtType" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="HasLighting" class="form-check-input" />
        <label asp-for="HasLighting" class="form-check-label">是否有燈光</label>
        <span asp-validation-for="HasLighting" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">描述</label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">儲存修改</button>
    <a asp-action="Index" class="btn btn-secondary">返回列表</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<script>
        const taiwanCities = [
            "台北市", "新北市", "桃園市", "台中市", "台南市", "高雄市",
            "基隆市", "新竹市", "嘉義市",
            "新竹縣", "苗栗縣", "彰化縣", "南投縣", "雲林縣", "嘉義縣",
            "屏東縣", "宜蘭縣", "花蓮縣", "台東縣", "澎湖縣", "金門縣", "連江縣"
        ];

        const citySelect = document.getElementById("citySelect");
        const districtSelect = document.getElementById("districtSelect");

        // 把原本值抓出來，順便去掉前後空白
        const selectedCity = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((Model.City ?? "").Trim()));
        const selectedDistrict = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((Model.District ?? "").Trim()));

        // 建立城市選單
        for (const city of taiwanCities) {
            const option = document.createElement("option");
            option.value = city;
            option.text = city;
            citySelect.appendChild(option);
        }

        // 直接指定原本城市
        citySelect.value = selectedCity;

        function loadDistricts(city, selectedDistrictValue = "") {
            districtSelect.innerHTML = '<option value="">請選擇地區</option>';

            if (!city) {
                return;
            }

            fetch(`/Courts/GetDistricts?city=${encodeURIComponent(city)}`)
                .then(response => response.json())
                .then(data => {
                    for (const district of data) {
                        const option = document.createElement("option");
                        option.value = district;
                        option.text = district;
                        districtSelect.appendChild(option);
                    }

                    // 地區載入完後再指定原本值
                    districtSelect.value = selectedDistrictValue;
                })
                .catch(error => {
                    console.error("載入地區失敗", error);
                });
        }

        // 頁面打開時，先載入原本城市的地區
        loadDistricts(selectedCity, selectedDistrict);

        // 使用者改城市時，重新載入地區
        citySelect.addEventListener("change", function () {
            loadDistricts(this.value);
        });
        console.log("selectedCity:", selectedCity);
    console.log("selectedDistrict:", selectedDistrict);
    console.log("citySelect:", citySelect);
</script>
