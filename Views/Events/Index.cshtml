@model IEnumerable<打球啊.Models.Event>

<h1>活動列表</h1>
<p>
    <a asp-action="Create" class="btn btn-success">新增活動</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>活動名稱</th>
            <th>日期</th>
            <th>球場</th>
            <th>功能</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.EventDate</td>
                <td>@item.Court?.Name</td>

                <td>
                    <!-- 進入 Details -->
                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-primary">
                        查看
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>